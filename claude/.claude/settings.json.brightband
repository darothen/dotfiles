{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(npm run :*)",
      "Bash(pytest :*)",
      "Bash(python -m pytest :*)",
      "Bash(ls :*)",
      "Edit(~/workspace/**/*.ts)",
      "Edit(~/workspace/**/*.py)",
      "Edit(~/workspace/**/*.js)",
      "Edit(~/workspace/**/*.json)",
      "Edit(~/workspace/**/*.yaml)",
      "Edit(~/workspace/**/*.yml)",
      "Edit(~/workspace/**/*.md)"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/daniel/.claude/permission-alert.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "cwd=$(cat | jq -r '.workspace.current_dir'); dir=\"${cwd/#$HOME/~}\"; git_part=\"\"; if git -C \"$cwd\" rev-parse --git-dir >/dev/null 2>&1; then branch=$(git -C \"$cwd\" symbolic-ref --short HEAD 2>/dev/null || git -C \"$cwd\" rev-parse --short HEAD 2>/dev/null); dirty=\"\"; git -C \"$cwd\" diff --quiet 2>/dev/null && git -C \"$cwd\" diff --cached --quiet 2>/dev/null || dirty=\" *\"; git_part=\"  ${branch}${dirty}\"; fi; printf '%s%s  %s' \"$dir\" \"$git_part\" \"$(date +%H:%M)\""
  },
  "alwaysThinkingEnabled": true,
  "model": "opus"
}
