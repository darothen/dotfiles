{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(uv run:*)",
      "Bash(uv sync)",
      "Bash(uv sync:*)",
      "Bash(uv pip:*)",
      "Bash(uvx:*)",
      "Bash(pixi run:*)",
      "Bash(pixi install)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pre-commit run:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(make:*)",
      "Bash(just:*)",
      "Bash(npm run:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(jq:*)",
      "Bash(which:*)",
      "Bash(env)",
      "Bash(printenv:*)",
      "Bash(ps:*)",
      "Bash(python3:*)",
      "Bash(test:*)",
      "Bash(date:*)",
      "Bash(gh:*)",
      "Bash(td:*)",
      "mcp__claude_ai_Google_Calendar__list_events",
      "mcp__claude_ai_Google_Calendar__list_calendars",
      "mcp__claude_ai_Google_Drive__read_file_content",
      "mcp__claude_ai_Google_Drive__download_file_content",
      "mcp__claude_ai_Google_Drive__get_file_metadata",
      "mcp__claude_ai_Google_Drive__search_files",
      "mcp__claude_ai_Linear__list_issues",
      "mcp__claude_ai_Linear__get_issue",
      "mcp__claude_ai_Linear__list_projects",
      "mcp__claude_ai_Linear__list_teams",
      "mcp__4d16d17e-d63b-41fc-a9f1-686597d2df74__list_events",
      "mcp__4d16d17e-d63b-41fc-a9f1-686597d2df74__list_calendars",
      "mcp__4d16d17e-d63b-41fc-a9f1-686597d2df74__get_event",
      "mcp__157537cf-1d31-4772-bdad-8e1f4ea7b1c0__read_file_content",
      "mcp__157537cf-1d31-4772-bdad-8e1f4ea7b1c0__get_file_metadata",
      "mcp__157537cf-1d31-4772-bdad-8e1f4ea7b1c0__search_files",
      "mcp__67ebd9e3-c60a-4b7e-ae9d-6c1ac29b804f__list_issues",
      "mcp__67ebd9e3-c60a-4b7e-ae9d-6c1ac29b804f__get_issue",
      "mcp__67ebd9e3-c60a-4b7e-ae9d-6c1ac29b804f__list_comments",
      "mcp__67ebd9e3-c60a-4b7e-ae9d-6c1ac29b804f__list_projects",
      "mcp__67ebd9e3-c60a-4b7e-ae9d-6c1ac29b804f__list_teams",
      "mcp__ffb67181-0a18-4d4e-b8ec-876c58467fad__search_threads",
      "mcp__ffb67181-0a18-4d4e-b8ec-876c58467fad__get_thread",
      "mcp__ffb67181-0a18-4d4e-b8ec-876c58467fad__list_labels",
      "Edit(~/workspace/**/*.ts)",
      "Edit(~/workspace/**/*.py)",
      "Edit(~/workspace/**/*.js)",
      "Edit(~/workspace/**/*.json)",
      "Edit(~/workspace/**/*.yaml)",
      "Edit(~/workspace/**/*.yml)",
      "Edit(~/workspace/**/*.md)",
      "Edit(~/workspace/**/*.toml)",
      "Edit(~/workspace/**/*.sh)",
      "Edit(~/software/dotfiles/**)",
      "Edit(~/Documents/workspace/**)",
      "Write(~/workspace/**)",
      "Write(~/software/dotfiles/**)",
      "Write(~/Documents/workspace/**)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ],
    "additionalDirectories": [
      "~/Documents/workspace"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/daniel/.claude/permission-alert.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/daniel/.claude/post-edit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/daniel/.claude/task-complete.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "cwd=$(cat | jq -r '.workspace.current_dir'); dir=\"${cwd/#$HOME/~}\"; git_part=\"\"; if git -C \"$cwd\" rev-parse --git-dir >/dev/null 2>&1; then branch=$(git -C \"$cwd\" symbolic-ref --short HEAD 2>/dev/null || git -C \"$cwd\" rev-parse --short HEAD 2>/dev/null); dirty=\"\"; git -C \"$cwd\" diff --quiet 2>/dev/null && git -C \"$cwd\" diff --cached --quiet 2>/dev/null || dirty=\" *\"; git_part=\"  ${branch}${dirty}\"; fi; printf '%s%s  %s' \"$dir\" \"$git_part\" \"$(date +%H:%M)\""
  },
  "enabledPlugins": {
    "duckdb-skills@duckdb-skills": true
  },
  "extraKnownMarketplaces": {
    "duckdb-skills": {
      "source": {
        "source": "github",
        "repo": "duckdb/duckdb-skills"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "verbose": true,
  "preferredNotifChannel": "ghostty",
  "mcpServers": {
    "zotero": {
      "command": "/Users/daniel/.local/bin/zotero-mcp",
      "env": {
        "ZOTERO_LOCAL": "true"
      }
    }
  }
}
